# ── AI Providers ──────────────────────────────────────────────────────────────
# OpenAI — platform.openai.com/api-keys (cover letter, diagrams, quizzes)
OPENAI_API_KEY=

# Anthropic — console.anthropic.com (resume analyser, interview prep, mentor)
ANTHROPIC_API_KEY=

# Google Gemini — aistudio.google.com/app/apikey (YouTube video analysis)
GEMINI_API_KEY=

# ── Job Search APIs ────────────────────────────────────────────────────────────
# RapidAPI → JSearch (Google Jobs): rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=

# Adzuna job search: developer.adzuna.com → My Apps
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ScraperAPI Google Jobs (AU live source): scraperapi.com → Dashboard
SCRAPERAPI_KEY=

# ── Content ────────────────────────────────────────────────────────────────────
# YouTube Data API v3: console.cloud.google.com → Credentials
YOUTUBE_API_KEY=

# ── Supabase ───────────────────────────────────────────────────────────────────
# supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-side only, NEVER expose to browser
# supabase.com → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ─────────────────────────────────────────────────────────────────────
# Use test keys (sk_test_) for development, live keys for production.
# dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=

# Webhook signing secret — dashboard.stripe.com → Developers → Webhooks → endpoint → Signing secret
# Events to subscribe: checkout.session.completed, customer.subscription.updated,
# customer.subscription.deleted, invoice.payment_succeeded, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=

# Recurring price ID for the Pro plan — dashboard.stripe.com → Products → Pro → price_…
STRIPE_PRICE_ID=

# One-time price ID for B2B job listings ($99 AUD) — dashboard.stripe.com → Products → Job Listing → price_…
STRIPE_JOB_LISTING_PRICE_ID=

# ── Logo CDN ───────────────────────────────────────────────────────────────────
# Logo.dev (company logos) — logo.dev → Dashboard → publishable token (safe to expose)
NEXT_PUBLIC_LOGO_DEV_TOKEN=

# ── App ────────────────────────────────────────────────────────────────────────
# Production URL (used for Stripe redirect URLs and OG images)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Owner email — grants admin access + bypasses rate limits (server-side only)
OWNER_EMAIL=

# ── Email (Resend) ─────────────────────────────────────────────────────────────
# Resend — resend.com → API Keys (for transactional emails: job listing confirmations, expiry notices)
RESEND_API_KEY=

# Cron job secret — must match the Authorization: Bearer header Vercel sends on /api/cron/* routes
# Set in Vercel dashboard: Settings → Environment Variables → CRON_SECRET
CRON_SECRET=

# ── Setup instructions ─────────────────────────────────────────────────────────
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in the values above
# 3. Run: npm run dev
#
# For a fresh team member with Vercel CLI installed:
#   vercel link && vercel env pull .env.local
# This pulls all secrets from Vercel directly (no manual copy-paste needed).
